# Auth
ADMIN_EMAIL=you@gmail.com
ADMIN_PASSWORD=your_strong_password
JWT_SECRET=long_random_string_min_32_chars
JWT_EXPIRE_DAYS=7

# Database
DATABASE_URL=postgresql+asyncpg://user:pass@host/dbname

# Supabase
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_KEY=your_service_key
SUPABASE_BUCKET=alphaengine-models

# LLM (currently trade decisions are rule-based; key kept for future Gemini mode)
GEMINI_API_KEY=your_gemini_key
# rules = deterministic only, hybrid = rules + LLM interpretation, gemini = LLM-first with hard safety rails
AGENT_DECISION_MODE=hybrid

# Market Data
ALPHA_VANTAGE_KEY=your_key
NEWS_API_KEY=your_key
# Get free Stooq key: open https://stooq.com/q/d/?s=aapl.us&get_apikey, solve captcha, copy key from download URL.
STOOQ_API_KEY=your_stooq_apikey
STOOQ_FIRST=true
ALLOW_SYNTHETIC_MARKET_DATA=false
ALLOW_SYNTHETIC_NEWS=false
ALLOW_SEARCH_FALLBACK_TICKERS=false

# Agent scheduler
AGENT_CRON_ENABLED=true
AGENT_CRON_DAY_OF_WEEK=mon-fri
AGENT_CRON_HOUR=9
AGENT_CRON_MINUTE=35
AGENT_CRON_HOURS=9,12,15

# App
ENVIRONMENT=production
MARKET_TIMEZONE=America/New_York
CORS_ORIGINS=http://localhost:3000,https://alphaenginestock.vercel.app
KEEP_ALIVE_URL=http://127.0.0.1:8000/health
AUTO_CREATE_TABLES=true
# On Render, set this to your service URL (e.g. https://alphaengine-api.onrender.com)
RENDER_EXTERNAL_URL=https://your-render-service.onrender.com
